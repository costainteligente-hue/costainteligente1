{
  "expo": {
    "name": "Costa Inteligente",
    "slug": "costa-inteligente",
    "version": "1.0.0",
    "scheme": "costainteligente",
    "orientation": "portrait",
    "icon": "./assets/images/Logo_No_LETRAS.jpg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/Logo_No_LETRAS.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#F0F8FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mx.costainteligente.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Necesitamos tu ubicación para el mapa y el módulo SOS de emergencia.",
        "NSLocationAlwaysUsageDescription": "El módulo SOS requiere acceso a tu ubicación para emergencias en el mar.",
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para subir fotos de capturas.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tu galería para subir fotos a la comunidad."
      }
    },
    "android": {
      "package": "mx.costainteligente.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Logo_No_LETRAS.jpg",
        "backgroundColor": "#F0F8FF"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/Logo_No_LETRAS.jpg"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Requerida para el módulo SOS de emergencia."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/REPLACE_WITH_PROJECT_ID"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
