# ─── Supabase ─────────────────────────────────────────────────────────────────
# Copia desde Supabase → tu proyecto → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── PostgreSQL / Railway ─────────────────────────────────────────────────────
# Copia desde Railway → tu proyecto → Variables → DATABASE_URL
DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# Para Expo (acceso desde cliente web/móvil)
EXPO_PUBLIC_DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# ─── App ──────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id

# ─── Resend (correos transaccionales) ────────────────────────────────────────
# Crea tu API key gratis en resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@costainteligente.mx

# ─── Mercado Pago (solo backend, nunca exponer al cliente) ────────────────────
# MP_ACCESS_TOKEN=APP_USR-...
# MP_WEBHOOK_SECRET=your-webhook-secret
